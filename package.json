{
  "name": "amnote",
  "version": "1.0.0",
  "description": "AI驱动的个人知识管理平台 - Windows桌面笔记软件",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "node -e \"require('fs').writeFileSync('pkgname.txt', 'output-exe-' + Date.now())\" && npm run build && electron-builder --dir && npm run clean:build",
    "package:installer": "node -e \"require('fs').writeFileSync('pkgname.txt', 'output-exe-' + Date.now())\" && npm run build && electron-builder && npm run clean:build",
    "clean:build": "node -e \"var fs=require('fs');['out','dist'].forEach(function(d){try{fs.rmSync(d,{recursive:true,force:true})}catch(e){}})\"",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint src --ext .ts,.vue --fix",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "dayjs": "^1.11.13",
    "echarts": "^6.1.0",
    "element-plus": "^2.14.1",
    "highlight.js": "^11.11.1",
    "jszip": "^3.10.1",
    "markdown-it": "^14.2.0",
    "sql.js": "^1.12.0",
    "ssh2-sftp-client": "^12.1.1",
    "vue-echarts": "^8.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.12",
    "@vitejs/plugin-vue": "^6.0.7",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.2",
    "electron-vite": "^5.0.0",
    "pinia": "^3.0.4",
    "typescript": "^5.7.2",
    "vite": "^7.3.5",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "vue-tsc": "^2.2.0"
  }
}
